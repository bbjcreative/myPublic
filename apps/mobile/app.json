{
  "expo": {
    "name": "TransitMY",
    "slug": "transit-my",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "my.transit.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TransitMY uses your location to show nearby stops and provide get-off alerts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TransitMY uses your location in the background to trigger get-off alerts during navigation.",
        "GADApplicationIdentifier": "ca-app-pub-5181607198940787~9879382689"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      },
      "package": "my.transit.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5181607198940787~2782126917",
          "iosAppId": "ca-app-pub-5181607198940787~9879382689"
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "REPLACE_WITH_EAS_PROJECT_ID" }
    }
  }
}
